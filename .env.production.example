# Production env for docker-compose.prod.yml. Copy to `.env` on the server and
# fill in. Do NOT commit the real file.
#
# Pick a host you'll use to reach the app, e.g. a hostname like `vault.home`
# (recommended — Twitch may reject a bare IP) or your unraid LAN IP.
# Use the SAME host in SITE_ADDRESS, BETTER_AUTH_URL, PUBLIC_HOST and
# OAUTH_REDIRECT_URL below, all over https.

# ── Database / Redis (service names from docker-compose.prod.yml) ─────
POSTGRES_USER=vault
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=vault
DATABASE_URL=postgresql://vault:change-me-strong@postgres:5432/vault
REDIS_URL=redis://redis:6379

# ── Twitch app (https://dev.twitch.tv/console) ───────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Empty = open signup (anyone with Twitch). Set ids (comma-sep) to restrict.
ALLOWED_TWITCH_USER_IDS=

# ── HTTPS host (Caddy) ───────────────────────────────────────────────
# The https URL Caddy serves and you browse to.
SITE_ADDRESS=https://vault.home

# ── Better Auth ──────────────────────────────────────────────────────
BETTER_AUTH_URL=https://vault.home
# openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── App host wiring ──────────────────────────────────────────────────
# Host only (no scheme) — used as the Twitch embed `parent`.
PUBLIC_HOST=vault.home
# Must be registered verbatim in the Twitch dev console as an OAuth redirect.
OAUTH_REDIRECT_URL=https://vault.home/api/auth/callback/twitch

# ── Notifications (Phase 5, unused) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=
