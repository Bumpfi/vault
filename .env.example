# ── Infra ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vault:vault@localhost:5432/vault
REDIS_URL=redis://localhost:6379

# ── Twitch app (https://dev.twitch.tv/console) ───────────────────────
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Comma-separated Twitch numeric user ids allowed to log in.
# Empty/unset = open signup (anyone with a Twitch account gets their own Vault).
# Set to a list (id1,id2) to restrict — recommended if exposing beyond Tailscale.
ALLOWED_TWITCH_USER_IDS=

# ── Better Auth ──────────────────────────────────────────────────────
BETTER_AUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── Hosting (prod / Tailscale — Phase 8) ─────────────────────────────
# Tailnet hostname; used as the Twitch embed `parent` and OAuth host.
PUBLIC_HOST=vault.<tailnet>.ts.net
# Dev redirect is http://localhost:3000/...; register the prod one too.
OAUTH_REDIRECT_URL=http://localhost:3000/api/auth/callback/twitch

# ── Notifications (Phase 5) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
